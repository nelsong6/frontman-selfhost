 type variant = Streaming | Completed
 
+type quoteStyle = CodeFence | Blockquote
+
+let quoteIntoPrompt: (string, string) => unit = %raw(`
+  function(text, style) {
+    var quote;
+    if (style === "blockquote") {
+      quote = text.split("\\n").map(function(line) {
+        return line.length === 0 ? ">" : "> " + line;
+      }).join("\\n");
+    } else {
+      var fence = String.fromCharCode(96) + String.fromCharCode(96) + String.fromCharCode(96);
+      quote = fence + "\\n" + text + "\\n" + fence;
+    }
+
+    var editor = document.querySelector('[role="textbox"][contenteditable="true"]');
+    if (!editor) return;
+
+    editor.focus();
+    var current = editor.textContent || "";
+    var textToInsert = current.trim().length === 0 ? quote : "\\n\\n" + quote;
+    var sel = window.getSelection();
+    if (sel) {
+      var range = document.createRange();
+      range.selectNodeContents(editor);
+      range.collapse(false);
+      sel.removeAllRanges();
+      sel.addRange(range);
+    }
+
+    if (document.queryCommandSupported && document.queryCommandSupported("insertText")) {
+      document.execCommand("insertText", false, textToInsert);
+    } else {
+      editor.appendChild(document.createTextNode(textToInsert));
+    }
+    editor.dispatchEvent(new InputEvent("input", {bubbles: true, inputType: "insertText", data: textToInsert}));
+  }
+`)
+
+let quoteStyleToString = style =>
+  switch style {
+  | CodeFence => "code"
+  | Blockquote => "blockquote"
+  }
+
+module MessageActionButton = {
