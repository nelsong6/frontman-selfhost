+      type_="button"
+      className="flex items-center justify-center w-5 h-5 border-none bg-transparent rounded cursor-pointer opacity-50 hover:opacity-80 transition-opacity text-zinc-200"
+      title
+      onClick={_ => onClick()}
+    >
+      {children}
+    </button>
+  }
+}
+
